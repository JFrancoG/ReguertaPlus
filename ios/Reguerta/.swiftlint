included:
  - Reguerta
  - ReguertaTests
  - ReguertaUITests

excluded:
  - Reguerta.xcodeproj
  - Reguerta.xcworkspace
  - .build
  - DerivedData
  - Pods


line_length:
  warning: 160
  error: 220

file_length:
  warning: 600
  error: 1200

type_body_length:
  warning: 350
  error: 600

type_name:
  min_length:
    warning: 3
    error: 2
  max_length:
    warning: 48
    error: 60

identifier_name:
  min_length:
    warning: 2
    error: 1
  max_length:
    warning: 56
    error: 64

reporter: "xcode"
